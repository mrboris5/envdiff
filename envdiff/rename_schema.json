{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EnvDiff Rename Result",
  "description": "Schema for the rename command JSON output",
  "type": "object",
  "required": ["applied", "skipped", "dry_run"],
  "properties": {
    "applied": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["old_key", "new_key"],
        "properties": {
          "old_key": { "type": "string" },
          "new_key": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dry_run": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
